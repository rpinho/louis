# Louis Slack bot — copy to .secrets/slack.env and fill in (see slack/SETUP.md).
# .secrets/ is gitignored; never commit real tokens.
SLACK_BOT_TOKEN=xoxb-...                 # Install App -> Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...                 # Basic Information -> App-Level Token, scope connections:write (Socket Mode)
#ANTHROPIC_API_KEY=sk-ant-...            # optional: enables natural-language answers (without it, deterministic engine summaries)
